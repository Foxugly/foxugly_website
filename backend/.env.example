# Variables d'environnement du backend foxugly (production).
# Destination sur le serveur : /run/foxugly/.env (tmpfs), chargé par systemd
# (EnvironmentFile). Régénéré à chaque boot depuis AWS SSM Parameter Store via
# foxugly-env.service (voir DEPLOY.md §2). Ce fichier n'est qu'un MODÈLE.

# Clé secrète Django — OBLIGATOIRE en prod. Générer :
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=change-me

DEBUG=False
ALLOWED_HOSTS=foxugly.com,www.foxugly.com

# Origines de confiance CSRF (le domaine public en https).
CSRF_TRUSTED_ORIGINS=https://foxugly.com,https://www.foxugly.com

# Sécurité HTTPS (à activer une fois le TLS en place sur nginx).
SECURE=True
SSL_REDIRECT=True
HSTS_SECONDS=31536000

# Gunicorn — instance t3.small PARTAGÉE avec quizonline (2 vCPU / 2 GiB) :
# écoute sur :8004 (quizonline garde :8000), 2 workers pour ménager la RAM.
GUNICORN_BIND=127.0.0.1:8004
GUNICORN_WORKERS=2

# Base de données — SQLite par défaut. Pour PostgreSQL, décommenter :
# DB_ENGINE=postgresql
# DB_NAME=foxugly
# DB_USER=foxugly
# DB_PASSWORD=change-me
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_CONN_MAX_AGE=60

# Sentry (monitoring d'erreurs) — laisser vide pour désactiver.
SENTRY_DSN=
SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0.0

# Formulaire de contact — envoi via Microsoft Graph (app Azure AD, permission
# applicative Mail.Send consentie admin). Vide = messages stockés mais non envoyés.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=contact@foxugly.com
CONTACT_RECIPIENT=contact@foxugly.com

# URL publique du site, utilisée dans les liens des emails (magic link).
# IMPORTANT en prod : doit pointer vers le domaine public canonique (avec www),
# sinon les magic links seront générés avec une mauvaise base d'URL.
SITE_URL=https://www.foxugly.com
