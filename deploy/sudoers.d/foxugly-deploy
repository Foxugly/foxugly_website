# /etc/sudoers.d/foxugly-deploy — sudo least-privilege pour les déploiements/ops foxugly.
#
# Accorde à l'utilisateur `django` UNIQUEMENT le contrôle de service (restart/reload),
# pour ne plus dépendre du sudo global de `ubuntu`. Aligné sur quizonline-deploy /
# pushit-deploy, avec un DURCISSEMENT : aucune commande `cp ... /etc/systemd/...` n'est
# accordée. Les fichiers d'unit restent gérés hors de l'arbre django (édités en root) ;
# autoriser leur copie depuis l'arbre applicatif (éditable par django) permettrait à un
# `django` compromis d'écrire une unit malveillante exécutée en root.
#
# Installation (par ROOT, depuis une copie vérifiée — JAMAIS par le script de déploiement) :
#   sudo visudo -c -f deploy/sudoers.d/foxugly-deploy
#   sudo install -m 0440 -o root -g root deploy/sudoers.d/foxugly-deploy /etc/sudoers.d/foxugly-deploy
#   sudo visudo -c
#
# Chemins ABSOLUS (vérifiés via `command -v systemctl nginx` sur Ubuntu 24.04).

Cmnd_Alias FOXUGLY_SVC = \
      /usr/bin/systemctl restart foxugly-gunicorn, \
      /usr/bin/systemctl restart foxugly-env, \
      /usr/bin/systemctl restart foxugly-env foxugly-gunicorn

Cmnd_Alias FOXUGLY_WEB = \
      /usr/sbin/nginx -t, \
      /usr/bin/systemctl reload nginx

django ALL=(root) NOPASSWD: FOXUGLY_SVC, FOXUGLY_WEB

Defaults!FOXUGLY_SVC,FOXUGLY_WEB !setenv, !env_keep
