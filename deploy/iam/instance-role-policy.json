{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadFoxuglyParams",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParametersByPath",
        "ssm:GetParameters",
        "ssm:GetParameter"
      ],
      "Resource": "arn:aws:ssm:eu-west-1:<ACCOUNT_ID>:parameter/foxugly/prod/*"
    },
    {
      "Sid": "DecryptSecureStringViaSSM",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEquals": { "kms:ViaService": "ssm.eu-west-1.amazonaws.com" }
      }
    }
  ]
}
