{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAppConfigFromSSM",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": [
        "arn:aws:ssm:eu-west-1:362629935151:parameter/foxugly/prod",
        "arn:aws:ssm:eu-west-1:362629935151:parameter/foxugly/prod/*"
      ]
    },
    {
      "Sid": "ReadDeployBundles",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::foxugly-deploy/builds/*"
    }
  ]
}
